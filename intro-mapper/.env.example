# Session signing secret (any long random string). Required in production.
SESSION_SECRET=change-me-to-a-long-random-string

# Postgres connection string (Neon or local). When unset, the app uses an
# in-memory store so it runs without a database for local development.
# DATABASE_URL=postgres://user:pass@host:5432/intro_mapper

# People Data Labs API key — used for target identity resolution + coworker
# overlap inference. Optional; target lookup degrades to manual entry without it.
# PDL_API_KEY=

# X (Twitter) OAuth 2.0 app credentials for follower/following sync (Phase 2).
# X_CLIENT_ID=
# X_CLIENT_SECRET=
# X_REDIRECT_URI=http://localhost:3000/api/oauth/x/callback
